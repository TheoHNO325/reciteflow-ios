{
  "name": "reciteflow-ios",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-document-picker": "^56.0.4",
    "expo-file-system": "^56.0.8",
    "expo-notifications": "^56.0.18",
    "expo-speech": "~56.0.3",
    "expo-speech-recognition": "^56.0.1",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:apk": "eas build --platform android --profile preview",
    "android:aab": "eas build --platform android --profile production",
    "ios": "expo start --ios",
    "ios:simulator": "eas build --platform ios --profile preview",
    "ios:ipa": "eas build --platform ios --profile production",
    "ios:submit": "eas submit --platform ios",
    "web": "expo start --web",
    "web:export": "npx expo export --platform web",
    "web:export:gh": "powershell -ExecutionPolicy Bypass -Command \"$env:EXPO_PUBLIC_BASE_PATH='/reciteflow-ios'; npx expo export --platform web\""
  },
  "private": true
}
